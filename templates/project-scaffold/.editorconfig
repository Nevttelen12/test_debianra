# ═══════════════════════════════════════════════
#  EditorConfig — Egységes kódformázás
#  https://editorconfig.org
#
#  Minden IDE/editor automatikusan felismeri
#  (VS Code, PHPStorm, Sublime, Vim, stb.)
# ═══════════════════════════════════════════════

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{js,ts,vue,jsx,tsx,css,scss,json}]
indent_size = 2

[*.blade.php]
indent_size = 4

[docker-compose*.yml]
indent_size = 2

[Makefile]
indent_style = tab
