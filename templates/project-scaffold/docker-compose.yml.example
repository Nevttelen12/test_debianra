# ═══════════════════════════════════════════════════════════════════
#  Laravel Projekt Docker Compose — Sablon
#
#  HASZNÁLAT:
#  1. Másold be a Laravel projekt gyökerébe docker-compose.yml néven
#  2. Cseréld ki a "PROJEKTNEV" szöveget a projekt nevére (kisbetűs, kötőjeles)
#  3. Futtasd: docker compose up -d
#  4. Nyisd meg: https://PROJEKTNEV.test
#
#  Előfeltétel: A globális Traefik, MySQL és Redis már fut
#  (ansible-playbook setup.yml telepíti őket)
# ═══════════════════════════════════════════════════════════════════

services:
  # ─── PHP-FPM (Laravel) ───
  app:
    build:
      context: .
      dockerfile: Dockerfile
    # Ha nincs Dockerfile, használd ezt helyette:
    # image: php:8.3-fpm
    container_name: PROJEKTNEV-app
    restart: unless-stopped
    working_dir: /var/www/html
    volumes:
      - .:/var/www/html
    environment:
      # Adatbázis — a globális MySQL konténerhez csatlakozik
      DB_CONNECTION: mysql
      DB_HOST: global-mysql
      DB_PORT: 3306
      DB_DATABASE: PROJEKTNEV
      DB_USERNAME: root
      DB_PASSWORD: devroot

      # Redis — a globális Redis konténerhez csatlakozik
      REDIS_HOST: global-redis
      REDIS_PORT: 6379

      # Email — a globális Mailpithez csatlakozik
      MAIL_MAILER: smtp
      MAIL_HOST: global-mailpit
      MAIL_PORT: 1025
      MAIL_USERNAME: null
      MAIL_PASSWORD: null
      MAIL_ENCRYPTION: null

      # Session & Cache
      SESSION_DRIVER: redis
      CACHE_STORE: redis
      QUEUE_CONNECTION: redis
    networks:
      - traefik-public
      - internal

  # ─── Nginx (webszerver) ───
  nginx:
    image: nginx:alpine
    container_name: PROJEKTNEV-nginx
    restart: unless-stopped
    volumes:
      - .:/var/www/html:ro
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - app
    labels:
      # Traefik automatikusan felismeri és route-olja
      traefik.enable: "true"
      traefik.http.routers.PROJEKTNEV.rule: "Host(`PROJEKTNEV.test`)"
      traefik.http.routers.PROJEKTNEV.tls: "true"
      traefik.http.services.PROJEKTNEV.loadbalancer.server.port: "80"
    networks:
      - traefik-public
      - internal

  # ─── Queue Worker (opcionális) ───
  # queue:
  #   build:
  #     context: .
  #     dockerfile: Dockerfile
  #   container_name: PROJEKTNEV-queue
  #   restart: unless-stopped
  #   working_dir: /var/www/html
  #   command: php artisan queue:work redis --sleep=3 --tries=3
  #   volumes:
  #     - .:/var/www/html
  #   depends_on:
  #     - app
  #   networks:
  #     - traefik-public
  #     - internal

networks:
  traefik-public:
    external: true
  internal:
    driver: bridge
